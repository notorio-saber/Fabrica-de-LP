rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return isSignedIn() && userDoc().data.role == 'admin'; }
    function isOwner(slug) {
      return isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && userDoc().data.role == 'affiliate'
        && userDoc().data.slug == slug;
    }

    function isOwnerUpdatePermitted(slug) {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let permissions = resource.data.permissions;
      return isOwner(slug)
        && affected.hasOnly(['affiliateName', 'profileImageUrl', 'whatsappUrl', 'pixelId', 'themeId', 'headline', 'subheadline', 'buttonText', 'updatedAt'])
        && (!('affiliateName'   in affected) || permissions.allowAffiliateNameEdit)
        && (!('profileImageUrl' in affected) || permissions.allowProfileImageEdit)
        && (!('whatsappUrl'     in affected) || permissions.allowWhatsAppUrlEdit)
        && (!('pixelId'         in affected) || permissions.allowPixelEdit)
        && (!('themeId'         in affected) || permissions.allowThemeEdit)
        && (!('headline'        in affected) || permissions.allowHeadlineEdit)
        && (!('subheadline'     in affected) || permissions.allowSubheadlineEdit)
        && (!('buttonText'      in affected) || permissions.allowButtonTextEdit);
    }

    match /landingPages/{slug} {
      allow get: if resource.data.status == 'active' || isAdmin() || isOwner(slug);
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isOwnerUpdatePermitted(slug);
    }

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() ||
        (isSignedIn() && request.auth.uid == uid &&
         request.resource.data.role == 'admin' &&
         !exists(/databases/$(database)/documents/bootstrap/admin));
      allow update, delete: if isAdmin();
    }

    // One-time marker: whoever creates this claims the first admin account.
    // Once it exists, the self-provisioning branch above is closed forever.
    match /bootstrap/admin {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
  }
}
