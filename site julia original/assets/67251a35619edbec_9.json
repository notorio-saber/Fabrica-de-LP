: scale(1.3);\r\n  opacity: 1;\r\n}\r\n\r\n\/* MOBILE *\/\r\n@media (max-width: 768px) {\r\n  .logo-set-unique img {\r\n    height: 80px !important;\r\n    margin: 0 30px;\r\n  }\r\n}\r\n\r\n@keyframes scrollUnique {\r\n  from { transform: translateX(0); }\r\n  to { transform: translateX(-50%); }\r\n}\r\n<\/style>\r\n\r\n<script>\r\nconst trackUnique = document.getElementById('logoTrackUnique');\r\nconst logosUnique = trackUnique.querySelectorAll('img');\r\n\r\nfunction highlightCenterLogoUnique() {\r\n  const center = window.innerWidth \/ 2;\r\n  let closest = null;\r\n  let closestDistance = Infinity;\r\n\r\n  logosUnique.forEach(logo => {\r\n    const rect = logo.getBoundingClientRect();\r\n    const logoCenter = rect.left + rect.width \/ 2;\r\n    const distance = Math.abs(center - logoCenter);\r\n\r\n    if (distance < closestDistance) {\r\n      closestDistance = distance;\r\n      closest = logo;\r\n    }\r\n  });\r\n\r\n  logosUnique.forEach(l => l.classList.remove('active'));\r\n  if (closest) closest.classList.add('active');\r\n}\r\n\r\nsetInterval(highlightCenterLogoUnique, 80);\r\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div data-aos=\"fade-up\" class=\"hostinger-elementor-aos elementor-element elementor-element-1771a7af e-flex e-con-boxed e-con e-parent\" data-id=\"1771a7af\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-6907a38f elementor-widget elementor-widget-heading\" data-id=\"6907a38f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Todos diretos reservados - \u00a9 2026<br>\n\ud83d\udd12 Site seguro<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-3cbfc216 elementor-widget elementor-widget-html\" data-id=\"3cbfc216\" data-element_type=\"widget\" data-e